# OpenClaw OpenShift Configuration Example
# Copy this file to .env and customize for your environment

###################
# Deployment Settings
###################

# Environment: lab or production
ENVIRONMENT=lab

# Namespace for OpenClaw deployment
NAMESPACE=openclaw

# OpenShift cluster URL
CLUSTER_URL=https://api.example.openshiftapps.com:443

###################
# OpenClaw Configuration
###################

# Gateway port (default: 18789)
OPENCLAW_GATEWAY_PORT=18789

# Gateway bind address
OPENCLAW_GATEWAY_BIND=0.0.0.0

# Enable sandbox mode (recommended: 1)
# Sandbox mode isolates tool executions in sub-containers
OPENCLAW_SANDBOX=1

# Logging level: debug, info, warn, error
LOG_LEVEL=info

###################
# Security & Authentication
###################

# Gateway authentication token
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_GENERATE_SECURE_TOKEN

###################
# AI Provider API Keys
# Configure at least one provider
###################

# Anthropic (Claude)
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (GPT models)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter (Multi-model access)
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AI (Gemini)
# Get your key at: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

###################
# Storage Configuration
###################

# Storage class for PersistentVolumeClaim
# Leave empty to use cluster default
# STORAGE_CLASS=gp3-csi

# Storage size for workspace data
# Lab: 20Gi, Production: 100Gi
STORAGE_SIZE=40Gi

###################
# Resource Limits
###################

# Memory requests/limits
MEMORY_REQUEST=2Gi
MEMORY_LIMIT=8Gi

# CPU requests/limits (in millicores)
CPU_REQUEST=1000m
CPU_LIMIT=4000m

###################
# Route Configuration
###################

# Custom hostname for Route (optional)
# If not set, OpenShift will auto-generate a route
# ROUTE_HOSTNAME=openclaw.apps.example.com

# TLS termination: edge, passthrough, or reencrypt
TLS_TERMINATION=edge

###################
# Advanced Configuration
###################

# Image repository and tag
IMAGE_REPOSITORY=ghcr.io/openclaw/openclaw
IMAGE_TAG=2026.3.7

# Pull policy: Always, IfNotPresent, Never
IMAGE_PULL_POLICY=IfNotPresent

# Replica count (for production, consider 1 for stateful apps with RWO volumes)
REPLICAS=1

# Termination grace period (seconds)
TERMINATION_GRACE_PERIOD=60
